{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/itdojp/private-match-protocol/schemas/registry/verification-materials.v0.1.schema.json",
  "title": "Synthetic message verification-material registry v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_status",
    "scope",
    "materials"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "artifact_status": {
      "const": "test-only"
    },
    "scope": {
      "const": "synthetic conformance vectors only; no production algorithm or key is selected"
    },
    "materials": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/material"
      }
    }
  },
  "$defs": {
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_material_id",
        "mode",
        "algorithm_id",
        "key_id",
        "allowed_senders",
        "status",
        "not_before",
        "not_after",
        "test_only"
      ],
      "properties": {
        "verification_material_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+~-]*$"
        },
        "mode": {
          "enum": [
            "signature",
            "mac",
            "profile-attestation"
          ]
        },
        "algorithm_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+~-]*$"
        },
        "key_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+~-]*$"
        },
        "allowed_senders": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+~-]*$"
          }
        },
        "status": {
          "enum": [
            "active",
            "expired",
            "revoked"
          ]
        },
        "not_before": {
          "type": "string",
          "format": "date-time"
        },
        "not_after": {
          "type": "string",
          "format": "date-time"
        },
        "test_only": {
          "const": true
        }
      }
    }
  }
}
